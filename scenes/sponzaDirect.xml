<scene>
    <camera type="perspective">
        <transform name="toWorld">
            <lookat origin="15.0, 3.0, 0.0" target="0, 1.5, 0.0" up="0, 1, 0"/>
        </transform>
        <float name="fov" value="60"/>
        <integer name="width" value="800"/>
        <integer name="height" value="600"/>
    </camera>

    <sampler type="independent">
        <integer name="spp" value="512"/>
    </sampler>

    <integrator type="direct"/>

    <primitive>
        <transform name="toWorld">
            <scale x="1.0" y="1.0" z="1.0"/>
            <translate x="0" y="0" z="0"/>
        </transform>
        <shape type="mesh">
            <string name="filename" value="sponza.obj"/>
        </shape>
        <material type="matte">
            <texture type="checkerboard_color" name="albedo">
                <color name="value1" value="0.5 0.5 0.5"/>
                <color name="value2" value="0.2 0.2 0.2"/>
                <vector2 name="scale" value="0.5 0.5"/>
            </texture>
        </material>
    </primitive>

    <primitive>
        <transform name="toWorld">
            <translate x="0" y="10" z="0"/>
        </transform>
        <shape type="sphere">
            <float name="radius" value="1.5"/>
        </shape>
        <material type="matte">
            <color name="albedo" value="0 0 0"/>
        </material>
        <emitter type="area">
            <color name="radiance" value="20 18 15"/>
        </emitter>
    </primitive>

    <primitive>
        <transform name="toWorld">
            <translate x="-12" y="2" z="4"/>
        </transform>
        <shape type="sphere">
            <float name="radius" value="0.8"/>
        </shape>
        <material type="matte">
            <color name="albedo" value="0 0 0"/>
        </material>
        <emitter type="area">
            <color name="radiance" value="2 5 10"/>
        </emitter>
    </primitive>

    <primitive>
        <transform name="toWorld">
            <translate x="12" y="3" z="-3"/>
        </transform>
        <shape type="sphere">
            <float name="radius" value="0.5"/>
        </shape>
        <material type="matte">
            <color name="albedo" value="0 0 0"/>
        </material>
        <emitter type="area">
            <color name="radiance" value="8 6 2"/>
        </emitter>
    </primitive>
</scene>